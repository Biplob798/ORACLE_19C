DESCRIBE v$parameter

select name from v$tablespace;


-- TO SHOW LIST OF BASIC PARAMETERS IN ORACLE, YOU CAN USE THE FOLLOWING SQL QUERY:

select name,value,type,ISBASIC,ISDEFAULT 
from v$parameter where  isbasic ='TRUE';

-- TO SHOW LIST OF NON-BASIC OR ADVANCED PARAMETERS IN ORACLE, YOU CAN USE THE FOLLOWING SQL QUERY:

select name,value,type,ISBASIC,ISDEFAULT 
from v$parameter where  isbasic ='FALSE';

-- TO SHOW THE VALUE OF A SPECIFIC PARAMETER, YOU CAN USE THE FOLLOWING SQL QUERY:

DESC V$PARAMETER
select name,value,type,ISSYS_MODIFIABLE,ISDEFAULT 
from v$parameter where  ISSYS_MODIFIABLE ='FALSE';

-- TO SHOW THE VALUE OF A DYNAMIC PARAMETER, YOU CAN USE THE FOLLOWING SQL QUERY:


select name,ISSYS_MODIFIABLE,ISDEFAULT,type,value
from v$parameter where  ISSYS_MODIFIABLE IN ('IMMEDIATE','DEFERED')
ORDER BY 1;


